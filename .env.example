# =============================================================================
# Telegram Aircraft Alert Bot - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# --- MongoDB ---
# If using MongoDB Atlas, paste your connection string here.
# Example: mongodb+srv://username:password@cluster0.mongodb.net/
MONGO_URI=mongodb://localhost:27017
DATABASE_NAME=aircraft_bot

# --- Aircraft Data Providers (5 Sources) ---
ADSB_LOL_BASE_URL=https://api.adsb.lol/v2
ADSB_FI_BASE_URL=https://api.adsb.fi/v2
OPENSKY_BASE_URL=https://opensky-network.org/api
OPENSKY_TOKEN_URL=https://auth.opensky-network.org/auth/realms/opensky-network/protocol/openid-connect/token
AIRPLANES_LIVE_BASE_URL=https://api.airplanes.live/v2
ADSB_ONE_BASE_URL=https://api.adsb.one/v2

# Directory containing OpenSky API key JSON files (OAuth2 format)
# Format per file: {"clientId": "...", "clientSecret": "..."}
API_KEYS_DIR=api

# --- AI Providers (Free Tiers) ---
# Gemini API Key (Google AI Studio)
GEMINI_API_KEY=

# Groq API Key (Groq Console — 30 RPM unlimited daily)
GROQ_API_KEY=

# --- Monitoring Settings ---
# Polling interval in seconds (lower is faster detection; default 10s)
POLL_INTERVAL_SECONDS=10

# Default monitoring radius in kilometers
DEFAULT_RADIUS_KM=50

# Notification cooldown in minutes (same aircraft won't re-notify within this window)
COOLDOWN_MINUTES=30

# --- Per-User Learning ---
# Number of unique aircraft to observe per user/region before selecting optimal providers
LEARNING_PLANE_THRESHOLD=100
RELEARN_PLANE_COUNT=25

# --- Admin ---
# Your Telegram user ID for admin alerts (optional)
ADMIN_TELEGRAM_ID=

# Optional password for the web admin panel
ADMIN_PASSWORD=

# --- Server ---
LOG_LEVEL=INFO
