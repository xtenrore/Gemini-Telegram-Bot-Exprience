# =============================================================================
# Telegram Aircraft Alert Bot - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# --- MongoDB ---
# If using MongoDB Atlas, paste your connection string here.
# Example: mongodb+srv://username:password@cluster0.mongodb.net/
MONGO_URI=mongodb://localhost:27017
DATABASE_NAME=aircraft_bot

# --- Aircraft Data Providers ---
# ADSB.lol (Primary - no key required, unlimited)
ADSB_LOL_BASE_URL=https://api.adsb.lol/v2

# ADSB.fi (Fallback - no key required, 1 req/s)
ADSB_FI_BASE_URL=https://api.adsb.fi/v2

# OpenSky Network (uses key rotation from api/*.json files)
OPENSKY_BASE_URL=https://opensky-network.org/api

# Directory containing OpenSky API key JSON files
# Each file should be: {"username": "...", "password": "..."}
API_KEYS_DIR=api

# --- Monitoring Settings ---
# Polling interval in seconds (how often to check for aircraft)
POLL_INTERVAL_SECONDS=45

# Default monitoring radius in kilometers
DEFAULT_RADIUS_KM=50

# Notification cooldown in minutes (same aircraft won't re-notify within this window)
COOLDOWN_MINUTES=30

# --- Admin ---
# Your Telegram user ID for admin alerts (optional)
ADMIN_TELEGRAM_ID=

# Optional password for the web admin panel (leave empty to rely on Caddy access control)
ADMIN_PASSWORD=

# --- Server ---
# FastAPI server host and port
HOST=0.0.0.0
PORT=8000

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO


